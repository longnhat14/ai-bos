    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.4.5"
  }
}
