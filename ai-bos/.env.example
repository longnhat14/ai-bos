NODE_ENV=development
PORT=3000

# Bao mat: danh sach domain duoc phep goi API (CORS), cach nhau boi dau phay.
# BAT BUOC dien truoc khi len production - de trong se CANH BAO va mo cho MOI domain.
# Vi du: ALLOWED_ORIGINS=https://pctech.vn,https://remoteit.com,https://admin.aibos.vn
ALLOWED_ORIGINS=

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=ai_bos
DB_PASSWORD=ai_bos_password
DB_NAME=ai_bos

# Redis (Event Bus / BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=doi-chuoi-nay-thanh-random-secret-that-dai-truoc-khi-len-production

# Tenant mac dinh cho Sprint 1 (chua co multi-tenant that)
DEFAULT_TENANT_CODE=pctech

# Warranty (Sprint 7)
DEFAULT_WARRANTY_MONTHS=3

# Chat / Auto-Translate (chi ap dung cho tenant RemoteIT) - can API key that de dich
# Lay tai: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# WhatsApp Business API (Meta Cloud API) - kenh chinh cho khach hang RemoteIT
# (My/Chau Au: Anh, Canada, Uc, New Zealand). Lay tai: https://developers.facebook.com
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=doi-chuoi-nay-thanh-chuoi-bat-ky-tu-chon-luc-dang-ky-voi-meta
WHATSAPP_TENANT_CODE=remoteit

# Telegram Bot (noi bo: admin, ky thuat vien, giam doc) - lay tai @BotFather tren Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=doi-chuoi-nay-thanh-chuoi-bat-ky-tu-chon

# Zalo OA (khach hang Viet Nam, chu yeu PCTech) - lay tai https://developers.zalo.me
ZALO_OA_ACCESS_TOKEN=
ZALO_APP_SECRET=
ZALO_TENANT_CODE=pctech
